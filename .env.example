# Quanta — variables de entorno (plantilla)
#
# Copiá este archivo como `.env` en la raíz y rellená los valores reales.
# Los paquetes individuales pueden tener su propio `.env.example` con subset específico.
# Convención: `NEXT_PUBLIC_*` para client-side, resto server-only.

# ─── Aplicación (apps/web) ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GAME_SERVER_URL=ws://localhost:2567

# ─── Supabase (packages/db + apps/web) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─── Colyseus (apps/game-server) ────────────────────────────────
GAME_SERVER_PORT=2567

# ─── AI Gateway (packages/ai-gateway) ───────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
ELEVENLABS_API_KEY=
# Opcionales / self-hosted
GOOGLE_CLOUD_TTS_KEY_PATH=
POLLINATIONS_BASE_URL=https://image.pollinations.ai
COQUI_TTS_BASE_URL=
PIPER_BASE_URL=

# ─── AI Gateway config (no credenciales) ────────────────────────
AI_GATEWAY_TIMEOUT_TEXT_MS=30000
AI_GATEWAY_TIMEOUT_IMAGE_MS=60000
AI_GATEWAY_TIMEOUT_AUDIO_MS=30000
AI_GATEWAY_RATE_TEXT_PER_MIN=30
AI_GATEWAY_RATE_IMAGE_PER_MIN=10
AI_GATEWAY_RATE_AUDIO_PER_MIN=20

# ─── Observabilidad (opcional) ──────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

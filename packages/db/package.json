{
  "name": "@quanta/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:migrate": "supabase migration up --local",
    "db:reset": "supabase db reset --local",
    "db:gen-types": "supabase gen types typescript --local > ../types/src/db.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@quanta/types": "workspace:*",
    "@supabase/supabase-js": "^2.47.10"
  },
  "devDependencies": {
    "@quanta/config": "workspace:*",
    "eslint": "^9.17.0",
    "supabase": "^2.2.1",
    "typescript": "^5.6.3"
  }
}
